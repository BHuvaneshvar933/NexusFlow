// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      String     @default("user") // "user" or "admin"
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  workspaceMembers WorkspaceMember[]
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   WorkspaceMember[]
  workflows Workflow[]
  dataStores DataStore[]
  secrets   Secret[]
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  role        String   @default("editor") // "owner", "admin", "editor", "viewer"
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, workspaceId])
}

model Workflow {
  id          String      @id @default(uuid())
  name        String
  description String?
  triggerType String      // e.g., "MANUAL", "WEBHOOK", "CRON"
  cronExpression String?  // e.g., "0 * * * *"
  testPayload String?     // Default JSON payload for manual testing
  isActive    Boolean     @default(false)
  
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  actions     Action[]
  executions  Execution[]
}

model Action {
  id         String   @id @default(uuid())
  actionType String   // e.g., "SEND_EMAIL", "AI_ANALYZE", "SAVE_TO_DB"
  sequence   Int      // Order of execution (1, 2, 3...)
  config     Json     // Action-specific settings
  
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Execution {
  id          String    @id @default(uuid())
  status      String    @default("pending") // pending, running, success, failed
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  logs        Json?     // Array of execution steps
  error       String?
  triggerData Json?     // The original trigger body, used for replay
  
  workflowId  String
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model DataStore {
  id          String   @id @default(uuid())
  collection  String   // e.g., "leads", "users"
  data        Json
  createdAt   DateTime @default(now())

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Secret {
  id          String   @id @default(uuid())
  name        String   // e.g., "STRIPE_KEY"
  description String?  // e.g., "Production stripe key"
  value       String   // Encrypted value
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
}
